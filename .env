# AI Provider Configuration (Server-Side Only)
VITE_USE_LIVE_AI=false           # Toggle between live AI and mock provider
AI_PROVIDER=openai               # AI provider: "openai" or "anthropic"
AI_API_KEY=                      # Required for live mode - API key (never bundled)
AI_MODEL=gpt-4o-mini             # Model to use (gpt-4o-mini for OpenAI, claude-3-haiku for Anthropic)
AI_TIMEOUT_MS=30000              # Request timeout in milliseconds
AI_MAX_TOKENS=1500               # Maximum tokens for response

# Security Note: AI_API_KEY is only used server-side in Vite middleware
# It never gets bundled into client JavaScript - safe for production