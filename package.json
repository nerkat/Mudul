{
  "name": "agent-workbench",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "echo \"(placeholder) run dev in subpackages\"",
    "build": "echo \"(placeholder) build all\"",
    "typecheck": "echo \"(placeholder) typecheck all\"",
    "db:setup": "cd packages/storage && node seed-manual.cjs",
    "db:reset": "if [ \"$NODE_ENV\" = \"production\" ]; then echo \"ERROR: Cannot reset database in production\"; exit 1; else cd packages/storage && rm -f dev.db && node seed-manual.cjs; fi"
  },
  "dependencies": {
    "react-router-dom": "^7.8.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6"
  }
}