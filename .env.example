# AI Provider Configuration
USE_LIVE_AI=false              # Toggle between live OpenAI and mock provider
ALLOW_FALLBACK=true            # When false, return 502 errors instead of fallback

# OpenAI Provider Settings
OPENAI_API_KEY=                # Required for live mode - get from OpenAI dashboard
OPENAI_MODEL=gpt-4o-mini       # OpenAI model to use (gpt-4o-mini, gpt-4, etc.)
OPENAI_TIMEOUT_MS=30000        # Request timeout in milliseconds
# OPENAI_BASE_URL=https://api.openai.com/v1   # Optional override for Azure/OpenRouter
# 
# Azure OpenAI Example:
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# Note: Azure uses 'api-key' header instead of 'Authorization'
#
# OpenRouter Example:  
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...    # OpenRouter API key