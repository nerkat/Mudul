    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@mudul/core": "workspace:*",
    "@prisma/client": "^5.11.0",
    "argon2": "^0.31.2",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^5.1.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.0.0",
    "prisma": "^5.11.0",
    "tsx": "^4.16.0",
    "typescript": "^5.0.0"
  }
}